{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Editor",
  "version": "0.1.0",
  "identifier": "com.editor.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "windows": [
      {
        "title": "Editor",
        "url": "/projects",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Video",
    "shortDescription": "Editor — a simple, powerful video editor.",
    "longDescription": "Editor is a desktop video editor. Trim, layer, and export — fast.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
